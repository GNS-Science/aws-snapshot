# Copy to .env and adjust for your environment.
# .env is gitignored — it will not be committed.
#
# The committed config template is `backup-config.example.yaml` —
# copy that to a per-install file (e.g. backup-config.production.yaml
# or wherever your install keeps its operational config) and point
# BACKUP_CONFIG_PATH at it. The example below assumes your install
# follows the GNS layout where production config lives in a sibling
# private repo (nzshm-backup-ops) — adjust paths to taste.
#
# BACKUP_CONFIG_PATH=../nzshm-backup-ops/backup-config.production.yaml
# AWS_PROFILE=<your-aws-profile>
